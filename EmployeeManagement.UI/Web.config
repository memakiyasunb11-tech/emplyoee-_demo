<?xml version="1.0" encoding="utf-8"?>
<!--
  Web.config - ASP.NET Application Configuration File
  Contains: Connection strings, session settings, custom errors,
            authentication, and httpRuntime settings.
  IMPORTANT: Update the connection string below to match
             your SQL Server instance.
-->
<configuration>

  <!-- ==========================================
       STARTUP: Target framework for .NET 4.8
       ========================================== -->
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <!-- ==========================================
       CONNECTION STRINGS
       Update Server and credentials as needed.
       Integrated Security = Windows Auth (no password)
       For SQL Auth: User Id=sa;Password=YourPassword;
       ========================================== -->
  <connectionStrings>
    <add name="EmployeeDBConnection"
         connectionString="Server=localhost;Database=EmployeeDB;Integrated Security=True;MultipleActiveResultSets=True;Connection Timeout=30;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <!-- ==========================================
       APPLICATION SETTINGS
       ========================================== -->
  <appSettings>
    <!-- Session timeout in minutes -->
    <add key="SessionTimeout" value="30" />
    <!-- Upload folder for employee photos (relative to app root) -->
    <add key="UploadFolder" value="~/Images/Uploads/" />
    <!-- Max photo upload size in KB -->
    <add key="MaxPhotoSizeKB" value="2048" />
    <!-- Application Name -->
    <add key="AppName" value="Employee Management System" />
    <!-- Company Name -->
    <add key="CompanyName" value="Your Company Name" />
  </appSettings>

  <system.web>

    <!-- ==========================================
         COMPILATION: Debug mode for development
         Set debug="false" in production
         ========================================== -->
    <compilation debug="true" targetFramework="4.8">
      <assemblies>
        <add assembly="System.Data, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" />
      </assemblies>
    </compilation>

    <!-- ==========================================
         HTTP RUNTIME: Max file upload = 10MB
         ========================================== -->
    <httpRuntime targetFramework="4.8" maxRequestLength="10240" executionTimeout="300" />

    <!-- ==========================================
         AUTHENTICATION: Forms-based login
         loginUrl = redirect to Login.aspx if not authenticated
         ========================================== -->
    <authentication mode="Forms">
      <forms loginUrl="~/Login.aspx"
             timeout="30"
             name=".ASPXAUTH"
             slidingExpiration="true" />
    </authentication>

    <!-- ==========================================
         AUTHORIZATION: Deny anonymous users globally
         ========================================== -->
    <authorization>
      <deny users="?" />
    </authorization>

    <!-- ==========================================
         SESSION STATE: 30 minute cookie-based session
         ========================================== -->
    <sessionState mode="InProc" timeout="30" cookieless="false" />

    <!-- ==========================================
         CUSTOM ERRORS: Redirect on errors
         ========================================== -->
    <customErrors mode="RemoteOnly" defaultRedirect="~/Error.aspx">
      <error statusCode="404" redirect="~/Error.aspx?code=404" />
      <error statusCode="500" redirect="~/Error.aspx?code=500" />
    </customErrors>

    <!-- ==========================================
         PAGES: Master page and theme defaults
         ========================================== -->
    <pages controlRenderingCompatibilityVersion="4.5">
    </pages>

    <!-- ==========================================
         GLOBALIZATION: UTF-8 for all pages
         ========================================== -->
    <globalization requestEncoding="utf-8" responseEncoding="utf-8" culture="en-IN" uiCulture="en-US" />

  </system.web>

  <!-- ==========================================
       ALLOW ANONYMOUS ACCESS: Login and ForgotPassword
       pages are excluded from authorization
       ========================================== -->
  <location path="Login.aspx">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="ForgotPassword.aspx">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <location path="Images">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>

  <!-- ==========================================
       SYSTEM.WEBSERVER: IIS-specific settings
       ========================================== -->
  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <modules>
      <remove name="TelemetryCorrelationHttpModule" />
    </modules>
    <security>
      <requestFiltering>
        <!-- Allow file uploads up to 10MB -->
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>
  </system.webServer>

</configuration>
